@model List<kkkk11.Models.Db.User>

@{
    ViewData["Title"] = "User List";
}

<h2>User List</h2>

<table border="1" cellpadding="10" cellspacing="0">
    <thead>
        <tr>
            <th>User ID</th>
            <th>Username</th>
            <th>Password</th>
            <th>Full Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Role ID</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.UserId</td>
                <td>@item.Username</td>
                <td>@item.Password</td>
                <td>@item.FullName</td>
                <td>@item.Email</td>
                <td>@item.Phone</td>
                <td>@item.RoleId</td>
                <td>@item.Status</td>
            </tr>
        }
    </tbody>
</table>