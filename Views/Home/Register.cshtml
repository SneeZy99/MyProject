@model kkkk11.ViewModels.RegisterViewModel

@{
    ViewBag.Title = "สมัครสมาชิก";
}

@{
    Layout = "~/Views/Shared/_blankLayout.cshtml";
}

<style>
    body {
        background:
            url('/images/hotel.jpg') no-repeat center center fixed;
        background-size: cover;
    }
</style>

<div class="container" style="max-width:500px; margin:60px auto;">
    <div class="card shadow border-0" style="border-radius:16px;">
        <div class="card-body p-5">
            <h3 class="text-center fw-bold mb-4">📝 สมัครสมาชิก</h3>

            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">ชื่อ-นามสกุล</label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Username</label>
                    <input asp-for="Username" class="form-control" />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">เบอร์โทร</label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">รหัสผ่าน</label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">ยืนยันรหัสผ่าน</label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn w-100 fw-bold text-white"
                        style="background:#c9a84c; border-radius:10px; padding:12px;">
                    สมัครสมาชิก
                </button>
            </form>

            <hr />
            <p class="text-center mb-0">
                มีบัญชีแล้ว?
                <a asp-action="Login" style="color:#c9a84c;">เข้าสู่ระบบ</a>
            </p>
        </div>
    </div>
</div>