@{
    ViewData["Title"] = "Hotel Booking";
}

<style>
.hero {
    background-image: url('/images/hotel.jpg');
    background-size: cover;
    background-position: center;
    height: 350px;
    border-radius: 15px;
    display:flex;
    align-items:center;
    justify-content:center;
    color:white;
}

.hero h1{
    background: rgba(0,0,0,0.5);
    padding:20px 40px;
    border-radius:10px;
}
</style>

<div class="container py-4">

    <!-- HERO -->
    <div class="hero mb-5">
        <h1>ยินดีต้อนรับสู่ Hotel Booking</h1>
    </div>


    <!-- PROMOTION -->
    <div class="card shadow-sm border-0 rounded-4 mb-5">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h5 class="fw-bold text-primary">โปรโมชั่นสำหรับสมาชิกใหม่</h5>
                <p class="text-muted mb-0">รับส่วนลดทันที 10% สำหรับการจองครั้งแรก</p>
            </div>

            <a asp-controller="Room" asp-action="Index" class="btn btn-primary">
                ดูห้องพัก
            </a>
        </div>
    </div>


    <!-- ROOM TYPES -->
    <h4 class="fw-bold mb-4">ประเภทห้องพัก</h4>

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4">
                <img src="/images/room1.jpg" class="card-img-top">
                <div class="card-body">
                    <h5>Small Room</h5>
                    <p class="text-muted">ห้องขนาดเล็ก สำหรับ 1-2 คน</p>

                    <a class="btn btn-outline-primary w-100"
                       asp-controller="Room"
                       asp-action="Small">
                       ดูรายละเอียด
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4">
                <img src="/images/room2.jpg" class="card-img-top">
                <div class="card-body">
                    <h5>Medium Room</h5>
                    <p class="text-muted">ห้องขนาดกลาง สำหรับครอบครัว</p>

                    <a class="btn btn-outline-primary w-100"
                       asp-controller="Room"
                       asp-action="Medium">
                       ดูรายละเอียด
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4">
                <img src="/images/room3.jpg" class="card-img-top">
                <div class="card-body">
                    <h5>Large Room</h5>
                    <p class="text-muted">ห้องขนาดใหญ่ Luxury</p>

                    <a class="btn btn-outline-primary w-100"
                       asp-controller="Room"
                       asp-action="Large">
                       ดูรายละเอียด
                    </a>
                </div>
            </div>
        </div>

    </div>

</div>
