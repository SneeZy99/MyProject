@{
    ViewData["Title"] = "Hotel Booking";
}

<style>
    body {
        background-color: #f4f6f9;
    }

    /* ===== HERO ===== */
    .hero {
        background: linear-gradient(rgba(0, 0, 0, .55), rgba(0, 0, 0, .55)),
            url('/images/hotel.jpg');
        background-size: cover;
        background-position: center;
        height: 420px;
        border-radius: 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: white;
        text-align: center;
    }

    .hero h1 {
        font-weight: 700;
        letter-spacing: 1px;
    }

    /* ===== SEARCH BOX ===== */
    .booking-box {
        background: white;
        padding: 20px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, .15);
        margin-top: -50px;
    }

    /* ===== SECTION TITLE ===== */
    .section-title {
        font-weight: 700;
        margin-bottom: 25px;
    }

    /* ===== CARD STYLE ===== */
    .room-card {
        transition: .3s;
        border: none;
        border-radius: 18px;
        overflow: hidden;
    }

    .room-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 15px 30px rgba(0, 0, 0, .15);
    }

    .room-card img {
        height: 220px;
        object-fit: cover;
    }

    /* GOLD BUTTON */
    .btn-gold {
        background: #c9a96a;
        color: white;
        border: none;
    }

    .btn-gold:hover {
        background: #b89654;
        color: white;
    }
</style>


<div class="container py-4">

    <!-- HERO -->
    <div class="hero mb-4">
        <h1>Experience Luxury Hotel</h1>
        <p class="opacity-75">Comfort • Relax • Premium Service</p>
    </div>


    <!-- BOOKING SEARCH -->
    <div class="booking-box mb-5">
        <form class="row g-3" asp-controller="Room" asp-action="Index" method="get">

            <div class="col-md-3">
                <label>Check-in</label>
                <input type="date" name="checkIn" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")">
            </div>

            <div class="col-md-3">
                <label>Check-out</label>
                <input type="date" name="checkOut" class="form-control"
                       min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")">
            </div>

            <div class="col-md-3">
                <label>Guests</label>
                <select name="guests" class="form-select">
                    <option value="1">1 Guest</option>
                    <option value="2">2 Guests</option>
                    <option value="3">3 Guests</option>
                    <option value="4">Family</option>
                </select>
            </div>

            <div class="col-md-3 d-grid align-items-end">
                <button class="btn btn-gold">Search Rooms</button>
            </div>

        </form>
    </div>


    <!-- FEATURES -->
    <h4 class="section-title text-center">Why Choose Our Hotel</h4>

    <div class="row text-center mb-5">

        <div class="col-md-4">
            <h5>Gourmet Dining</h5>
            <p class="text-muted">อาหารระดับพรีเมียมจากเชฟมืออาชีพ</p>
        </div>

        <div class="col-md-4">
            <h5>Comfortable Rooms</h5>
            <p class="text-muted">ห้องพักหรู พร้อมสิ่งอำนวยความสะดวกครบ</p>
        </div>

        <div class="col-md-4">
            <h5>Excellent Service</h5>
            <p class="text-muted">บริการระดับโรงแรม 5 ดาว</p>
        </div>

    </div>

    <!-- PROMOTIONS -->
    <h4 class="section-title text-center mt-5">โปรโมชั่นพิเศษ</h4>

    <div class="row g-4 mb-5">

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100"
                 style="border-radius:16px; border-top:4px solid #c9a84c !important;">
                <div class="card-body p-4 text-center">
                    <h5 class="fw-bold mt-2">Early Bird</h5>
                    <div class="badge mb-2"
                         style="background:#c9a84c; font-size:1rem; padding:6px 16px; border-radius:20px;">
                        ลด 5%
                    </div>
                    <p class="text-muted small mt-2">จองล่วงหน้าอย่างน้อย 7 วัน รับส่วนลดทันที</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100"
                 style="border-radius:16px; border-top:4px solid #4c9ac9 !important;">
                <div class="card-body p-4 text-center">
                    <h5 class="fw-bold mt-2">Long Stay</h5>
                    <div class="badge mb-2"
                         style="background:#4c9ac9; font-size:1rem; padding:6px 16px; border-radius:20px;">
                        ลด 8-10%
                    </div>
                    <p class="text-muted small mt-2">พักติดต่อกัน 7 วัน ลด 8% / 10 วัน ลด 10%</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100"
                 style="border-radius:16px; border-top:4px solid #28a745 !important;">
                <div class="card-body p-4 text-center">
                    <h5 class="fw-bold mt-2">Loyal Customer</h5>
                    <div class="badge mb-2"
                         style="background:#28a745; font-size:1rem; padding:6px 16px; border-radius:20px;">
                        ลด 10-15%
                    </div>
                    <p class="text-muted small mt-2">สะสมการจองครบ 15 วัน ลด 10% / ครบ 30 วัน ลด 15%</p>
                </div>
            </div>
        </div>

    </div>


    <!-- ROOM TYPES -->
    <h4 class="section-title">Room Types</h4>

    <div class="row g-4">

        <!-- COZY -->
        <div class="col-md-4">
            <div class="card room-card">
                <img src="/images/1.jpg">
                <div class="card-body">
                    <h5>Cozy Room</h5>
                    <p class="text-muted">เหมาะสำหรับ 1-2 คน</p>
                    <a class="btn btn-outline-dark w-100" asp-controller="Room" asp-action="Details" asp-route-id="1">
                        View Details
                    </a>
                </div>
            </div>
        </div>

        <!-- DELUXE -->
        <div class="col-md-4">
            <div class="card room-card">
                <img src="/images/2.jpg">
                <div class="card-body">
                    <h5>Deluxe Room</h5>
                    <p class="text-muted">เหมาะสำหรับ 2-3 คน</p>

                    <a class="btn btn-outline-dark w-100" asp-controller="Room" asp-action="Details" asp-route-id="2">
                        View Details
                    </a>
                </div>
            </div>
        </div>

        <!-- FAMILY -->
        <div class="col-md-4">
            <div class="card room-card">
                <img src="/images/3.jpg">
                <div class="card-body">
                    <h5>Family Room</h5>
                    <p class="text-muted">เหมาะสำหรับ 4-6 คน</p>

                    <a class="btn btn-outline-dark w-100" asp-controller="Room" asp-action="Details" asp-route-id="3">
                        View Details
                    </a>
                </div>
            </div>
        </div>

    </div>

</div>
