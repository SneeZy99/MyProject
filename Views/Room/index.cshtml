@model List<kkkk11.Models.Db.Room>

<div class="row">
@foreach(var room in Model)
{
    <div class="col-md-4">
        <div class="card mb-4">

            <div class="card-body">
                <h5>@room.RoomName</h5>
                <p>@room.Price บาท</p>

                <a asp-action="Details"
                   asp-route-id="@room.RoomId"
                   class="btn btn-primary">
                   View Details
                </a>

            </div>
        </div>
    </div>
}
</div>
