@model kkkk11.Models.Db.Room

@{
    ViewBag.Title = "Room Details";
}

<style>
    body {
        background-color: #f4f6f9;
    }
</style>

<div class="container my-5">
    <div class="card shadow-lg border-0" style="border-radius:16px; overflow:hidden;">
        <div class="row g-0">

            <!-- รูปห้อง -->
            <div class="col-md-4">
                <img src="/images/@(Model.RoomTypeId).jpg"
                     class="img-fluid h-100" style="object-fit:cover; min-height:350px;" alt="Room Image" />
            </div>
            <!-- รายละเอียด -->
            <div class="col-md-8 p-5 d-flex flex-column justify-content-center">
                <span class="badge mb-3"
                      style="background:#c9a84c; font-size:0.85rem; width:fit-content; padding:6px 14px; border-radius:20px;">
                    ห้องเลขที่ @Model.RoomNumber
                </span>

                <h2 class="fw-bold mb-1">@Model.RoomType?.TypeName</h2>
                <p class="text-muted mb-4">@Model.RoomType?.Description</p>

                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <div class="p-3 rounded-3 text-center" style="background:#f8f8f8;">
                            <div class="fs-4"></div>
                            <div class="fw-semibold">@Model.RoomType?.Capacity คน</div>
                            <div class="text-muted small">ความจุ</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded-3 text-center" style="background:#f8f8f8;">
                            <div class="fs-4"></div>
                            <div class="fw-semibold">฿@Model.RoomType?.PricePerNight?.ToString("N0")</div>
                            <div class="text-muted small">ต่อคืน</div>
                        </div>
                    </div>
                </div>

                <!-- สถานะห้อง -->
                <div class="mb-4">
                    <span class="badge @(Model.RoomStatus?.StatusName == "Available" ? "bg-success" : "bg-danger")"
                          style="font-size:0.9rem; padding:8px 16px; border-radius:20px;">
                        @Model.RoomStatus?.StatusName
                    </span>
                </div>

                <!-- ปุ่ม -->
                <div class="d-flex gap-2">
                    @if (Model.RoomStatus?.StatusName == "Available")
                    {
                        <a asp-controller="Booking" asp-action="Create" asp-route-roomId="@Model.RoomId"
                               class="btn btn-warning fw-bold px-4"
                               style="background:#c9a84c; border:none; border-radius:10px;">
                            จองห้องนี้
                        </a>
                    }
                    <a asp-action="Index" asp-controller="Room" class="btn btn-outline-secondary px-4"
                           style="border-radius:10px;">
                        ← กลับ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>