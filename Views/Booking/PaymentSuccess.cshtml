@model kkkk11.Models.Db.Booking

@{
    ViewBag.Title = "ชำระเงินสำเร็จ";
}

<div class="container my-5 text-center" style="max-width:500px;">
    <div class="card shadow border-0 p-5" style="border-radius:16px;">
        <div style="font-size:4rem;">✅</div>
        <h3 class="fw-bold mt-3">ชำระเงินสำเร็จ!</h3>
        <p class="text-muted">การจองของคุณได้รับการยืนยันแล้ว</p>

        <div class="p-3 rounded-3 my-3 text-start" style="background:#f8f8f8;">
            <div class="d-flex justify-content-between mb-1">
                <span class="text-muted">ห้อง</span>
                <span class="fw-semibold">@Model?.Room?.RoomType?.TypeName</span>
            </div>
            <div class="d-flex justify-content-between mb-1">
                <span class="text-muted">Check-in</span>
                <span>@Model?.CheckInDate?.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="d-flex justify-content-between mb-1">
                <span class="text-muted">Check-out</span>
                <span>@Model?.CheckOutDate?.ToString("dd/MM/yyyy")</span>
            </div>
            <hr />
            <div class="d-flex justify-content-between fw-bold">
                <span>ยอดชำระ</span>
                <span style="color:#c9a84c;">฿@Model?.TotalPrice?.ToString("N0")</span>
            </div>
        </div>

        <div class="d-flex gap-2 mt-2">
            <a asp-controller="Booking" asp-action="MyBookings"
               class="btn btn-outline-secondary w-100" style="border-radius:10px;">
                การจองของฉัน
            </a>
            <a asp-controller="Home" asp-action="Index"
               class="btn w-100 text-white fw-bold"
               style="background:#c9a84c; border-radius:10px;">
                หน้าหลัก
            </a>
        </div>
    </div>
</div>