@model kkkk11.ViewModels.AddUserViewModel

@{
    ViewData["Title"] = "Add User";
}

<style>
    body {
        background-color: #f4f6f9;
    }
</style>
<div class="container mt-4">

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">

            <form asp-controller="Admin" asp-action="AddUser" method="post">

                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Full Name</label>
                        <input asp-for="FullName" class="form-control form-control-lg" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Email</label>
                        <input asp-for="Email" class="form-control form-control-lg" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Phone</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text">+66</span>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Role</label>
                        <select asp-for="RoleId" class="form-select form-select-lg">
                            <option value="">-- Select Role --</option>
                            <option value="1">Admin</option>
                            <option value="2">Receptionist</option>
                            <option value="3">Staff</option>
                            <option value="4">User</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Username</label>
                        <input asp-for="Username" class="form-control form-control-lg" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Password</label>
                        <input asp-for="Password" type="password" class="form-control form-control-lg" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Confirm Password</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg" />
                    </div>

                </div>

                <div class="d-flex justify-content-end mt-4">
                    <a asp-controller="Admin" asp-action="UserList" class="btn btn-outline-secondary me-2">Cancel</a>

                    <button class="btn btn-success" type="submit">Submit</button>
                </div>

            </form>

        </div>
    </div>
</div>
